{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "PYTHONPATH=. uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "preDeployPlan": {
      "steps": [
        {
          "command": "PYTHONPATH=. alembic upgrade head"
        }
      ]
    },
    "restartPolicyType": "ON_FAILURE"
  }
}
